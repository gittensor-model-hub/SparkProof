# yunwu.ai relay — OpenAI-compatible gateway (docs: https://yunwu.apifox.cn/)
# Use with: SPARKPROOF_GATEWAY=yunwu  or  sparkproof-generate --gateway yunwu
YUNWU_API_KEY=

# yunwu model slugs come from your token's 支持模型 list (/v1/models), NOT OpenRouter paths.
# Production pins the same teachers as OpenRouter: claude-fable-5 + gpt-5.6-sol only.
# Run: uv run sparkproof-yunwu-probe --list --test
YUNWU_MODEL_ANTHROPIC=claude-fable-5
YUNWU_MODEL_OPENAI=gpt-5.6-sol
# Optional alternate base (try if yunwu.ai fails): https://api.yunwu.cloud/v1
# YUNWU_API_BASE=https://yunwu.ai/v1

# Default gateway: openrouter | yunwu
SPARKPROOF_GATEWAY=openrouter

# Triton API docs (auto-fetched for api_doc prompts when no --doc-dir)
# SPARKPROOF_TRITON_DOCS_REF=v3.7.1
# SPARKPROOF_TRITON_DOCS_DIR=/path/to/triton/docs
# SPARKPROOF_TRITON_DOCS_CACHE=~/.cache/sparkproof/triton-docs
# SPARKPROOF_TRITON_DOCS_OFFLINE=1
# SPARKPROOF_TRITON_API_PAGES=1
# Optional: version-pinned mirror only; moving triton-lang.org/main is intentionally not implicit.
# SPARKPROOF_TRITON_API_PAGE_BASE=https://docs.example/triton/v3.7.1/python-api/generated

# Required for strict decontamination/release gating when SparkDistill is not a sibling checkout.
# SPARKPROOF_TRITONBENCH_PROBLEMS=/path/to/tritonbench/tritonbench/problems
# SPARKPROOF_TRITONBENCH_ROOT=/path/to/tritonbench
# SPARKPROOF_TRITONBENCH_PY_DIR=/path/to/held-out/benchmark/python
