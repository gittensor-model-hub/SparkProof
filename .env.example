# yunwu.ai relay — OpenAI-compatible gateway (docs: https://yunwu.apifox.cn/)
# Use with: SPARKPROOF_GATEWAY=yunwu  or  sparkproof-generate --gateway yunwu
YUNWU_API_KEY=

# yunwu model slugs come from your token's 支持模型 list (/v1/models), NOT OpenRouter paths.
# Defaults: claude-sonnet-5 (anthropic proxy), gpt-5-mini (openai proxy).
# Run: uv run sparkproof-yunwu-probe --list --test
YUNWU_MODEL_ANTHROPIC=claude-sonnet-5
YUNWU_MODEL_OPENAI=gpt-5-mini
# Optional alternate base (try if yunwu.ai fails): https://api.yunwu.cloud/v1
# YUNWU_API_BASE=https://yunwu.ai/v1

# Default gateway: openrouter | yunwu
SPARKPROOF_GATEWAY=openrouter
